[Unit]
Description=Sentinel Doorbell AI Edge Capture and Inference
After=network-online.target

[Service]
WorkingDirectory=/opt/sentinel-doorbell
EnvironmentFile=/opt/sentinel-doorbell/.env
ExecStart=/opt/sentinel-doorbell/.venv/bin/python scripts/benchmark_inference.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

